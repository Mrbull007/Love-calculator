<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Love Percentage Calculator ❤️</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: 'Arial', sans-serif;
      background: linear-gradient(135deg, #ff9a9e, #fad0c4);
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    .hearts-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      z-index: 1;
      pointer-events: none;
    }

    .heart {
      position: absolute;
      font-size: 30px;
      opacity: 0.3;
      animation: float 15s linear infinite;
    }

    @keyframes float {
      0% { transform: translateY(100vh) rotate(0deg); }
      100% { transform: translateY(-100px) rotate(360deg); }
    }

    .container {
      background: white;
      padding: 40px 50px;
      border-radius: 20px;
      box-shadow: 0 15px 35px rgba(0,0,0,0.2);
      text-align: center;
      max-width: 420px;
      width: 90%;
      z-index: 2;
      position: relative;
    }

    h1 {
      color: #e91e63;
      margin-bottom: 30px;
      font-size: 28px;
    }

    input {
      width: 100%;
      padding: 12px;
      margin: 10px 0;
      border: 2px solid #ff4081;
      border-radius: 10px;
      font-size: 16px;
      outline: none;
    }

    button {
      background: #e91e63;
      color: white;
      border: none;
      padding: 14px 30px;
      margin-top: 20px;
      border-radius: 50px;
      font-size: 18px;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      background: #c2185b;
      transform: scale(1.05);
    }

    .result {
      margin-top: 30px;
      padding: 20px;
      background: #fff0f5;
      border-radius: 15px;
      display: none;
    }

    .percentage {
      font-size: 48px;
      font-weight: bold;
      color: #e91e63;
    }
  </style>
</head>
<body>

  <div class="hearts-bg" id="hearts"></div>

  <div class="container">
    <h1>💖 Love Percentage Calculator 💖</h1>
    
    <input type="text" id="name1" placeholder="First Person's Name" required>
    <input type="text" id="name2" placeholder="Second Person's Name" required>
    
    <button onclick="calculateLove()">Calculate Love ❤️</button>

    <div class="result" id="result">
      <p id="names" style="font-size: 22px; margin: 10px 0;"></p>
      <p class="percentage" id="percentage"></p>
      <p id="message" style="font-size: 20px; margin: 15px 0;"></p>
    </div>
  </div>

  <script>
    // Create floating hearts background
    function createHearts() {
      const bg = document.getElementById('hearts');
      const hearts = ['❤️', '💕', '💖', '💗', '💓', '💞'];
      
      for (let i = 0; i < 40; i++) {
        const heart = document.createElement('div');
        heart.className = 'heart';
        heart.textContent = hearts[Math.floor(Math.random() * hearts.length)];
        heart.style.left = Math.random() * 100 + 'vw';
        heart.style.animationDuration = (Math.random() * 10 + 10) + 's';
        heart.style.animationDelay = '-' + Math.random() * 15 + 's';
        heart.style.fontSize = (Math.random() * 20 + 25) + 'px';
        bg.appendChild(heart);
      }
    }

    function calculateLove() {
      const name1 = document.getElementById('name1').value.trim();
      const name2 = document.getElementById('name2').value.trim();
      const resultDiv = document.getElementById('result');

      if (!name1 || !name2) {
        alert("Please enter both names ❤️");
        return;
      }

      const combined = (name1 + name2).toLowerCase().replace(/\s/g, '');
      let score = 0;
      for (let char of combined) {
        score += char.charCodeAt(0);
      }
      const percentage = score % 101;

      let message = "";
      let emoji = "";

      if (percentage < 30) {
        message = "Just friends... 💔";
        emoji = "💔";
      } else if (percentage < 50) {
        message = "There's a little spark! ✨";
        emoji = "💓";
      } else if (percentage < 70) {
        message = "Good chemistry! 🔥";
        emoji = "💕";
      } else if (percentage < 90) {
        message = "Amazing match! 💞";
        emoji = "💖";
      } else {
        message = "TRUE LOVE! Soulmates forever! ❤️‍🔥";
        emoji = "❤️‍🔥";
      }

      // Display result
      document.getElementById('names').innerHTML = `${name1} ❤️ ${name2}`;
      document.getElementById('percentage').innerHTML = `${percentage}% ${emoji}`;
      document.getElementById('message').textContent = message;
      resultDiv.style.display = "block";
    }

    // Initialize floating hearts
    window.onload = createHearts;
  </script>
</body>
</html>
